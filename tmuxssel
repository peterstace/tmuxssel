#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys

# Per-window tmux user option that holds a window's flag. Present (set to
# "1") means flagged; unset means not flagged. The name is part of the public
# interface: status-line formats test it directly (see the README).
FLAG_OPTION = "@ssel_flag"

# Marker shown before a session with a flagged window in the picker.
FLAG_MARKER = "● "


def main():
    args = parse_args()
    if args.command == "pick":
        pick(args)
    elif args.command == "flag":
        flag(args)


def parse_args():
    parser = argparse.ArgumentParser(
        description="pick a tmux session with fzf, or manage window flags"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    pick_parser = sub.add_parser(
        "pick",
        help="pick a tmux session with fzf, creating it from a git repo if needed",
    )
    pick_parser.add_argument(
        "--ignore",
        action="append",
        default=[],
        metavar="FRAGMENT",
        help="path fragments to ignore when searching for git repos",
    )
    pick_parser.add_argument(
        "--find-and-replace",
        action="append",
        default=[],
        metavar="FIND:REPLACE",
        help="git-repo-path to session-name find-and-replace directives "
        "(in the format FIND:REPLACE)",
    )
    pick_parser.add_argument(
        "--walk-start",
        default=os.environ.get("HOME", "/"),
        metavar="PATH",
        help="path to start walking from",
    )

    flag_parser = sub.add_parser(
        "flag",
        help="get, set, clear, toggle, or count window flags",
    )
    flag_parser.add_argument(
        "action",
        choices=["get", "set", "clear", "toggle", "count"],
        help="get/set/clear/toggle a window's flag, or count flagged windows",
    )
    flag_parser.add_argument(
        "window",
        nargs="?",
        metavar="WINDOW",
        help="window to act on (defaults to the current window)",
    )

    return parser.parse_args()


def pick(args):
    check_dependencies()
    fnrs = [parse_find_and_replace(d) for d in args.find_and_replace]

    # Maps each fzf display line to the (session_name, directory) it stands
    # for. Existing sessions map to a None directory (already created); repos
    # map to the directory to create their session in.
    display_to_target = {}
    seen_names = set()

    def candidates():
        flags = session_flag_map()
        for name in sorted(flags, key=lambda n: not flags[n]):
            line = (FLAG_MARKER if flags[name] else "") + name
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[line] = (name, None)
                yield line
        for path in walk_git_repos(args.walk_start, args.ignore):
            name = path
            for find, replace in fnrs:
                name = name.replace(find, replace)
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[name] = (name, path)
                yield name

    selected = fzf(candidates())
    if selected is None:
        return

    name, directory = display_to_target[selected]
    if not tmux_session_exists(name):
        tmux_new_session(name, directory)
    tmux_switch_session(name)


def flag(args):
    if args.action == "count":
        print(sum(flagged for _, _, flagged in tmux_list_windows()))
        return

    if args.window:
        window_id = resolve_window(args.window)
    else:
        window_id = current_window()

    if args.action == "get":
        print("1" if window_flag_map().get(window_id, False) else "0")
        return

    if args.action == "toggle":
        set_flag(window_id, not window_flag_map().get(window_id, False))
    elif args.action == "set":
        set_flag(window_id, True)
    elif args.action == "clear":
        set_flag(window_id, False)
    refresh_status()


def current_window():
    # A process running inside a pane has TMUX_PANE set to that pane, which
    # names its window unambiguously — even when a different window is the
    # most-recently-active one (e.g. an async task flagging its own window
    # after the user has switched away). The toggle key binding can't rely on
    # this, because run-shell does not set TMUX_PANE, so it passes the window
    # explicitly instead (see the README).
    pane = os.environ.get("TMUX_PANE")
    if pane:
        result = subprocess.run(
            ["tmux", "display-message", "-p", "-t", pane, "#{window_id}"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    sys.exit("cannot determine the current window; pass WINDOW explicitly")


def resolve_window(target):
    """Resolve a tmux window target to its window ID (@N), which is
    unambiguous and stable for the window's lifetime."""
    result = subprocess.run(
        ["tmux", "display-message", "-p", "-t", target, "#{window_id}"],
        capture_output=True,
        text=True,
    )
    window_id = result.stdout.strip()
    if result.returncode != 0 or not window_id:
        sys.exit(f"no such window: {target}")
    return window_id


def set_flag(window_id, flagged):
    # window_id is an @-prefixed window ID (see resolve_window and
    # current_window), so the -t target is unambiguous.
    if flagged:
        cmd = ["tmux", "set-option", "-w", "-t", window_id, FLAG_OPTION, "1"]
    else:
        cmd = ["tmux", "set-option", "-w", "-u", "-t", window_id, FLAG_OPTION]
    subprocess.run(cmd, check=True)


def refresh_status():
    # Redraw status lines immediately so the flag count and markers update
    # without waiting for status-interval. With no client attached there is
    # nothing to redraw, so ignore the resulting error.
    subprocess.run(["tmux", "refresh-client", "-S"], stderr=subprocess.DEVNULL)


def session_flag_map():
    """Return an ordered mapping of session name to whether any of its
    windows is flagged, in tmux's own session order."""
    flags = {}
    for session, _, flagged in tmux_list_windows():
        flags[session] = flags.get(session, False) or flagged
    return flags


def window_flag_map():
    """Return a mapping of window ID to flagged bool."""
    return {wid: flagged for _, wid, flagged in tmux_list_windows()}


def tmux_list_windows():
    """Return a list of (session_name, window_id, flagged) tuples covering
    every window on the server, in tmux's own session and window order."""
    result = subprocess.run(
        [
            "tmux",
            "list-windows",
            "-a",
            "-F",
            "#{session_name}\t#{window_id}\t#{" + FLAG_OPTION + "}",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.exit(f"tmux list-windows: {result.stderr.strip()}")
    windows = []
    for line in result.stdout.splitlines():
        if not line.strip():
            continue
        session, window_id, value = line.rsplit("\t", 2)
        windows.append((session, window_id, value != ""))
    return windows


def tmux_session_exists(name):
    result = subprocess.run(
        ["tmux", "has-session", "-t", "=" + name], capture_output=True
    )
    return result.returncode == 0


def tmux_new_session(name, directory):
    cmd = ["tmux", "new-session", "-s", name, "-d"]
    if directory:
        cmd += ["-c", directory]
    subprocess.run(cmd, check=True)


def tmux_switch_session(name):
    subcommand = "switch-client" if os.environ.get("TMUX") else "attach-session"
    subprocess.run(["tmux", subcommand, "-t", "=" + name], check=True)


def walk_git_repos(start, ignore):
    """Yield directories containing a .git entry, without descending
    into them or into ignored paths."""
    for dirpath, dirnames, filenames in os.walk(start):
        if any(fragment in dirpath for fragment in ignore):
            dirnames.clear()
            continue
        dirnames.sort()
        if ".git" in dirnames or ".git" in filenames:
            dirnames.clear()
            yield dirpath


def fzf(lines):
    """Run fzf, feeding it lines as they are produced.

    Returns the selection, or None if the user cancelled or nothing
    matched.
    """
    proc = subprocess.Popen(
        ["fzf"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True
    )
    try:
        for line in lines:
            proc.stdin.write(line + "\n")
            proc.stdin.flush()
    except BrokenPipeError:
        pass  # fzf exited before reading all input (selected early or cancelled)
    finally:
        try:
            proc.stdin.close()
        except BrokenPipeError:
            pass
    out = proc.stdout.read()
    status = proc.wait()
    if status in (1, 130):  # no match, or cancelled
        return None
    if status != 0:
        sys.exit(f"fzf exited with status {status}")
    return out.rstrip("\n")


def parse_find_and_replace(directive):
    find, sep, replace = directive.partition(":")
    if not sep:
        sys.exit("find-and-replace directive must be in the format: FIND:REPLACE")
    return find, replace


def check_dependencies():
    for cmd in (["tmux", "-V"], ["fzf", "--version"]):
        try:
            subprocess.run(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=True,
            )
        except (OSError, subprocess.CalledProcessError) as e:
            sys.exit(f"checking for {cmd[0]}: {e}")


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(str(e))
