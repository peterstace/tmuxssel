#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys

# Per-session tmux user option that holds a session's flag. Present (set to
# "1") means flagged; unset means not flagged. The name is an implementation
# detail: nothing outside this script needs to know it.
FLAG_OPTION = "@ssel_flag"

# Marker shown before a flagged session in the picker.
FLAG_MARKER = "● "


def main():
    args = parse_args()
    if args.command == "pick":
        pick(args)
    elif args.command == "flag":
        flag(args)


def parse_args():
    parser = argparse.ArgumentParser(
        description="pick a tmux session with fzf, or manage session flags"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    pick_parser = sub.add_parser(
        "pick",
        help="pick a tmux session with fzf, creating it from a git repo if needed",
    )
    pick_parser.add_argument(
        "--ignore",
        action="append",
        default=[],
        metavar="FRAGMENT",
        help="path fragments to ignore when searching for git repos",
    )
    pick_parser.add_argument(
        "--find-and-replace",
        action="append",
        default=[],
        metavar="FIND:REPLACE",
        help="git-repo-path to session-name find-and-replace directives "
        "(in the format FIND:REPLACE)",
    )
    pick_parser.add_argument(
        "--walk-start",
        default=os.environ.get("HOME", "/"),
        metavar="PATH",
        help="path to start walking from",
    )

    flag_parser = sub.add_parser(
        "flag",
        help="get, set, clear, toggle, or count session flags",
    )
    flag_parser.add_argument(
        "action",
        choices=["get", "set", "clear", "toggle", "count"],
        help="get/set/clear/toggle a session's flag, or count flagged sessions",
    )
    flag_parser.add_argument(
        "session",
        nargs="?",
        metavar="SESSION",
        help="session to act on (defaults to the current session)",
    )

    return parser.parse_args()


def pick(args):
    check_dependencies()
    fnrs = [parse_find_and_replace(d) for d in args.find_and_replace]

    # Maps each fzf display line to the (session_name, directory) it stands
    # for. Existing sessions map to a None directory (already created); repos
    # map to the directory to create their session in.
    display_to_target = {}
    seen_names = set()

    def candidates():
        flags = tmux_flag_map()
        for name in sorted(flags, key=lambda n: not flags[n]):
            line = (FLAG_MARKER if flags[name] else "") + name
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[line] = (name, None)
                yield line
        for path in walk_git_repos(args.walk_start, args.ignore):
            name = path
            for find, replace in fnrs:
                name = name.replace(find, replace)
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[name] = (name, path)
                yield name

    selected = fzf(candidates())
    if selected is None:
        return

    name, directory = display_to_target[selected]
    if not tmux_session_exists(name):
        tmux_new_session(name, directory)
    tmux_switch_session(name)


def flag(args):
    if args.action == "count":
        print(sum(tmux_flag_map().values()))
        return

    session = args.session or current_session()

    if args.action == "get":
        print("1" if tmux_flag_map().get(session, False) else "0")
        return

    require_session(session)
    if args.action == "toggle":
        set_flag(session, not tmux_flag_map().get(session, False))
    elif args.action == "set":
        set_flag(session, True)
    elif args.action == "clear":
        set_flag(session, False)
    refresh_status()


def current_session():
    # A process running inside a pane has TMUX_PANE set to that pane, which
    # names its session unambiguously — even when a different session is the
    # most-recently-active one (e.g. an async task flagging its own session
    # after the user has switched away). The toggle key binding can't rely on
    # this, because run-shell does not set TMUX_PANE, so it passes the session
    # explicitly instead (see the README).
    pane = os.environ.get("TMUX_PANE")
    if pane:
        result = subprocess.run(
            ["tmux", "display-message", "-p", "-t", pane, "#{session_name}"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    sys.exit("cannot determine the current session; pass SESSION explicitly")


def require_session(session):
    if not tmux_session_exists(session):
        sys.exit(f"no such session: {session}")


def set_flag(session, flagged):
    # The session is known to exist exactly (see require_session), so a bare
    # -t target resolves to it rather than prefix-matching another session.
    # set-option rejects the "=" exact-match prefix that the rest of the code
    # uses, so it can't be applied here.
    if flagged:
        cmd = ["tmux", "set-option", "-t", session, FLAG_OPTION, "1"]
    else:
        cmd = ["tmux", "set-option", "-u", "-t", session, FLAG_OPTION]
    subprocess.run(cmd, check=True)


def refresh_status():
    # Redraw status lines immediately so the flag count and marker update
    # without waiting for status-interval. With no client attached there is
    # nothing to redraw, so ignore the resulting error.
    subprocess.run(["tmux", "refresh-client", "-S"], stderr=subprocess.DEVNULL)


def tmux_flag_map():
    """Return an ordered mapping of session name to flagged bool, in tmux's
    own session order."""
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}\t#{" + FLAG_OPTION + "}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.exit(f"tmux list-sessions: {result.stderr.strip()}")
    flags = {}
    for line in result.stdout.splitlines():
        if not line.strip():
            continue
        name, _, value = line.partition("\t")
        flags[name] = value != ""
    return flags


def tmux_session_exists(name):
    result = subprocess.run(
        ["tmux", "has-session", "-t", "=" + name], capture_output=True
    )
    return result.returncode == 0


def tmux_new_session(name, directory):
    cmd = ["tmux", "new-session", "-s", name, "-d"]
    if directory:
        cmd += ["-c", directory]
    subprocess.run(cmd, check=True)


def tmux_switch_session(name):
    subcommand = "switch-client" if os.environ.get("TMUX") else "attach-session"
    subprocess.run(["tmux", subcommand, "-t", "=" + name], check=True)


def walk_git_repos(start, ignore):
    """Yield directories containing a .git entry, without descending
    into them or into ignored paths."""
    for dirpath, dirnames, filenames in os.walk(start):
        if any(fragment in dirpath for fragment in ignore):
            dirnames.clear()
            continue
        dirnames.sort()
        if ".git" in dirnames or ".git" in filenames:
            dirnames.clear()
            yield dirpath


def fzf(lines):
    """Run fzf, feeding it lines as they are produced.

    Returns the selection, or None if the user cancelled or nothing
    matched.
    """
    proc = subprocess.Popen(
        ["fzf"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True
    )
    try:
        for line in lines:
            proc.stdin.write(line + "\n")
            proc.stdin.flush()
    except BrokenPipeError:
        pass  # fzf exited before reading all input (selected early or cancelled)
    finally:
        try:
            proc.stdin.close()
        except BrokenPipeError:
            pass
    out = proc.stdout.read()
    status = proc.wait()
    if status in (1, 130):  # no match, or cancelled
        return None
    if status != 0:
        sys.exit(f"fzf exited with status {status}")
    return out.rstrip("\n")


def parse_find_and_replace(directive):
    find, sep, replace = directive.partition(":")
    if not sep:
        sys.exit("find-and-replace directive must be in the format: FIND:REPLACE")
    return find, replace


def check_dependencies():
    for cmd in (["tmux", "-V"], ["fzf", "--version"]):
        try:
            subprocess.run(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=True,
            )
        except (OSError, subprocess.CalledProcessError) as e:
            sys.exit(f"checking for {cmd[0]}: {e}")


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(str(e))
