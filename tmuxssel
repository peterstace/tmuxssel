#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys

# Per-window tmux user option marking a window as flagged. Set means flagged;
# unset means not flagged. tmuxssel only reads the option — raising and
# clearing flags is left to external tooling (see the README).
FLAG_OPTION = "@ssel_flag"

# Marker shown before a session with a flagged window in the picker.
FLAG_MARKER = "● "


def main():
    args = parse_args()
    pick(args)


def parse_args():
    parser = argparse.ArgumentParser(
        description="pick a tmux session with fzf, "
        "creating it from a git repo if needed",
    )
    parser.add_argument(
        "--ignore",
        action="append",
        default=[],
        metavar="FRAGMENT",
        help="path fragments to ignore when searching for git repos",
    )
    parser.add_argument(
        "--find-and-replace",
        action="append",
        default=[],
        metavar="FIND:REPLACE",
        help="git-repo-path to session-name find-and-replace directives "
        "(in the format FIND:REPLACE)",
    )
    parser.add_argument(
        "--walk-start",
        default=os.environ.get("HOME", "/"),
        metavar="PATH",
        help="path to start walking from",
    )
    return parser.parse_args()


def pick(args):
    check_dependencies()
    fnrs = [parse_find_and_replace(d) for d in args.find_and_replace]

    # Maps each fzf display line to the (session_name, directory) it stands
    # for. Existing sessions map to a None directory (already created); repos
    # map to the directory to create their session in.
    display_to_target = {}
    seen_names = set()

    def candidates():
        flags = session_flag_map()
        for name in sorted(flags, key=lambda n: not flags[n]):
            line = (FLAG_MARKER if flags[name] else "") + name
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[line] = (name, None)
                yield line
        for path in walk_git_repos(args.walk_start, args.ignore):
            name = path
            for find, replace in fnrs:
                name = name.replace(find, replace)
            if name not in seen_names:
                seen_names.add(name)
                display_to_target[name] = (name, path)
                yield name

    selected = fzf(candidates())
    if selected is None:
        return

    name, directory = display_to_target[selected]
    if not tmux_session_exists(name):
        tmux_new_session(name, directory)
    tmux_switch_session(name)


def session_flag_map():
    """Return an ordered mapping of session name to whether any of its
    windows is flagged, in tmux's own session order."""
    flags = {}
    for session, _, flagged in tmux_list_windows():
        flags[session] = flags.get(session, False) or flagged
    return flags


def tmux_list_windows():
    """Return a list of (session_name, window_id, flagged) tuples covering
    every window on the server, in tmux's own session and window order."""
    result = subprocess.run(
        [
            "tmux",
            "list-windows",
            "-a",
            "-F",
            "#{session_name}\t#{window_id}\t#{" + FLAG_OPTION + "}",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.exit(f"tmux list-windows: {result.stderr.strip()}")
    windows = []
    for line in result.stdout.splitlines():
        if not line.strip():
            continue
        session, window_id, value = line.rsplit("\t", 2)
        windows.append((session, window_id, value != ""))
    return windows


def tmux_session_exists(name):
    result = subprocess.run(
        ["tmux", "has-session", "-t", "=" + name], capture_output=True
    )
    return result.returncode == 0


def tmux_new_session(name, directory):
    cmd = ["tmux", "new-session", "-s", name, "-d"]
    if directory:
        cmd += ["-c", directory]
    subprocess.run(cmd, check=True)


def tmux_switch_session(name):
    subcommand = "switch-client" if os.environ.get("TMUX") else "attach-session"
    subprocess.run(["tmux", subcommand, "-t", "=" + name], check=True)


def walk_git_repos(start, ignore):
    """Yield directories containing a .git entry, without descending
    into them or into ignored paths."""
    for dirpath, dirnames, filenames in os.walk(start):
        if any(fragment in dirpath for fragment in ignore):
            dirnames.clear()
            continue
        dirnames.sort()
        if ".git" in dirnames or ".git" in filenames:
            dirnames.clear()
            yield dirpath


def fzf(lines):
    """Run fzf, feeding it lines as they are produced.

    Returns the selection, or None if the user cancelled or nothing
    matched.
    """
    proc = subprocess.Popen(
        ["fzf"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True
    )
    try:
        for line in lines:
            proc.stdin.write(line + "\n")
            proc.stdin.flush()
    except BrokenPipeError:
        pass  # fzf exited before reading all input (selected early or cancelled)
    finally:
        try:
            proc.stdin.close()
        except BrokenPipeError:
            pass
    out = proc.stdout.read()
    status = proc.wait()
    if status in (1, 130):  # no match, or cancelled
        return None
    if status != 0:
        sys.exit(f"fzf exited with status {status}")
    return out.rstrip("\n")


def parse_find_and_replace(directive):
    find, sep, replace = directive.partition(":")
    if not sep:
        sys.exit("find-and-replace directive must be in the format: FIND:REPLACE")
    return find, replace


def check_dependencies():
    for cmd in (["tmux", "-V"], ["fzf", "--version"]):
        try:
            subprocess.run(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=True,
            )
        except (OSError, subprocess.CalledProcessError) as e:
            sys.exit(f"checking for {cmd[0]}: {e}")


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(str(e))
